# ===== Auth (NextAuth) =====
# Required in production. Generate: `openssl rand -base64 32`
NEXTAUTH_SECRET=
# Public URL of the deployment (e.g. https://atlas-production-xxxx.up.railway.app)
NEXTAUTH_URL=

# Google SSO (sign up / login). Create at https://console.cloud.google.com
# OAuth consent screen + OAuth client (Web). Authorized redirect URI:
#   {NEXTAUTH_URL}/api/auth/callback/google
# Without these, the app falls back to a demo "guest" login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Translation engines (all optional — each falls back to demo) =====
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
